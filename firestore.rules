rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isFriend(ownerUid) {
      return isAuthed() && (
        request.auth.uid == ownerUid ||
        (
          exists(/databases/$(database)/documents/friendships/$(ownerUid)) &&
          request.auth.uid in get(/databases/$(database)/documents/friendships/$(ownerUid)).data.friendUids
        )
      );
    }

    match /users/{uid} {
      allow read: if isAuthed();
      allow create, update: if isOwner(uid);
      allow delete: if false;

      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      match /dailyStats/{dayId} {
        allow read: if isFriend(uid);
        allow write: if isOwner(uid);
      }

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    match /usernames/{username} {
      allow read: if isAuthed();
      allow create: if isAuthed() &&
        request.resource.data.uid == request.auth.uid &&
        !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if false;
    }

    match /friendRequests/{requestId} {
      allow create: if isAuthed() && request.resource.data.fromUid == request.auth.uid;
      allow read: if isAuthed() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow update: if isAuthed() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow delete: if false;
    }

    match /friendships/{uid} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() &&
        request.resource.data.friendUids is list &&
        (
          request.auth.uid == uid ||
          request.auth.uid in request.resource.data.friendUids
        );
      allow delete: if false;
    }

    match /focusRooms/{roomId} {
      allow read: if isAuthed() && request.auth.uid in resource.data.participantUids;
      allow create: if isAuthed() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.participantUids is list &&
        request.auth.uid in request.resource.data.participantUids;
      allow update: if isAuthed() &&
        request.auth.uid in resource.data.participantUids &&
        request.resource.data.participantUids is list;
      allow delete: if isAuthed() && resource.data.ownerUid == request.auth.uid;
    }

    match /friendChallenges/{challengeId} {
      allow create: if isAuthed() &&
        request.resource.data.creatorUid == request.auth.uid &&
        isFriend(request.resource.data.targetUid);
      allow read: if isAuthed() && (
        resource.data.creatorUid == request.auth.uid ||
        resource.data.targetUid == request.auth.uid
      );
      allow update: if isAuthed() && (
        resource.data.creatorUid == request.auth.uid ||
        resource.data.targetUid == request.auth.uid
      ) &&
      request.resource.data.creatorUid == resource.data.creatorUid &&
      request.resource.data.targetUid == resource.data.targetUid;
      allow delete: if isAuthed() && (
        resource.data.creatorUid == request.auth.uid ||
        resource.data.targetUid == request.auth.uid
      );
    }

    match /globalFeed/{entryId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
